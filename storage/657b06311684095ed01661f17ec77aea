fhand = urllib.request.urlopen( /quotesingle.ts1http://data.pr4e.org/romeo.txt/quotesingle.ts1)
for line in fhand:
print(line.decode().strip())
# Code: http://www.pythonlearn.com/code3/urllib1.py
